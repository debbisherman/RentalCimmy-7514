# ----------------------------------------------------------------------
# Optimized React SPA .htaccess for cPanel
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # 1. If the file exists as a real file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. Otherwise, send all requests to index.html
  # This prevents the "text/html" MIME error for missing JS files
  RewriteRule ^ index.html [L]
</IfModule>

# Ensure JS files have the correct MIME type
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType application/javascript .mjs
</IfModule>